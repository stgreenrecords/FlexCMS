{
  "name": "@flexcms/build-worker",
  "version": "1.0.0",
  "private": true,
  "description": "Static site compilation worker — pre-renders published pages to HTML and uploads to S3",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsup src/index.ts --format cjs --dts",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@flexcms/sdk": "workspace:*",
    "@flexcms/react": "workspace:*",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "amqplib": "^0.10.0",
    "@aws-sdk/client-s3": "^3.500.0",
    "pino": "^9.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/amqplib": "^0.10.0",
    "@types/node": "^20.11.0",
    "tsup": "^8.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "rimraf": "^5.0.0"
  }
}

