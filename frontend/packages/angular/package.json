{
  "name": "@flexcms/angular",
  "version": "1.0.0",
  "description": "Angular adapter for FlexCMS — renders CMS component trees as Angular components",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --external @angular/core --external @angular/common",
    "clean": "rimraf dist",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@flexcms/sdk": "workspace:*"
  },
  "peerDependencies": {
    "@angular/core": "^17.0.0 || ^18.0.0 || ^19.0.0",
    "@angular/common": "^17.0.0 || ^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@angular/core": "^17.0.0",
    "@angular/common": "^17.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "rimraf": "^5.0.0",
    "rxjs": "^7.8.0"
  },
  "files": ["dist"],
  "license": "MIT"
}

