{
  "name": "@flexcms/ui",
  "version": "1.0.0",
  "description": "FlexCMS Design System — themed, accessible UI components for the Admin UI",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./themes": {
      "import": "./dist/themes.mjs",
      "require": "./dist/themes.js",
      "types": "./dist/themes.d.ts"
    },
    "./globals.css": "./dist/globals.css"
  },
  "scripts": {
    "build": "tsup src/index.ts src/themes/index.ts --format cjs,esm --dts --external react",
    "dev": "tsup src/index.ts src/themes/index.ts --format cjs,esm --dts --external react --watch",
    "clean": "rimraf dist",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.0.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "tailwind-merge": "^2.2.0"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "react": "^18.2.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "rimraf": "^5.0.0",
    "tailwindcss": "^3.4.0"
  },
  "files": ["dist"],
  "license": "MIT"
}

