{
  "name": "@flexcms/vue",
  "version": "1.0.0",
  "description": "Vue 3 adapter for FlexCMS — renders CMS component trees as Vue components",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --external vue",
    "dev": "tsup src/index.ts --format cjs,esm --dts --external vue --watch",
    "clean": "rimraf dist",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@flexcms/sdk": "workspace:*"
  },
  "peerDependencies": {
    "vue": "^3.3.0"
  },
  "devDependencies": {
    "vue": "^3.4.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "rimraf": "^5.0.0"
  },
  "files": ["dist"],
  "license": "MIT"
}

